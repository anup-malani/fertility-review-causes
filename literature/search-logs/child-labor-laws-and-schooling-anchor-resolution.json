      "anchor": {
        "title": "Women's education, fertility and children's health during a gender equalization process: Evidence from a child labor reform in Spain",
        "authors": [
          "Cristina Belles-Obrero",
          "Antonio Cabrales",
          "Sergi Jimenez-Martin",
          "Judit Vall-Castello"
        ],
        "year": 2023,
